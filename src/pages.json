{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@/uni-module-common/components/uni-$1/uni-$1.vue",
      "^xxt-(.*)": "@/uni-module-common/components/xxt-components/xxt-$1/xxt-$1.vue",
      "^tui-(.*)": "@/uni-module-common/components/thorui/tui-$1/tui-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "name": "bookMainMine",
      "aliasPath": "/",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/mine/mine",
      "name": "bookMainMine",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/diary/diary",
      "name": "CoupleDiary",
      "style": {
        "navigationStyle": "custom"
      }
    }
  ],
  "subPackages": [
    {
      "root": "uni_modules/uni-module-public",
      "name": "xxtUniModulePublic",
      "pages": [
        {
          "path": "login/login",
          "name": "login",
          "aliasPath": "/",
          "style": {
            "navigationBarTitleText": "登录",
            "navigationBarBackgroundColor": "#4ad975",
            "navigationBarTextStyle": "white",
            "componentPlaceholder": {
              "star": "view"
            }
          }
        },
        {
          "path": "weChatFileSelect/index",
          "name": "weChatFileSelect",
          "aliasPath": "/",
          "style": {
            "navigationBarTitleText": "选取文件",
            "navigationBarBackgroundColor": "#4ad975",
            "navigationBarTextStyle": "white",
            "enablePullDownRefresh": false
          },
          "independent": true
        }
      ]
    },
    {
      "root": "uni_modules/pages-home",
      "name": "xxtPagesHomeModule",
      "pages": [
        {
          "path": "home-main/home-main",
          "name": "templateHomeMain",
          "style": {
            "navigationStyle": "custom"
          }
        }
      ]
    },
    {
      "root": "uni_modules/pages-mine",
      "name": "xxtPagesMineModule",
      "pages": [
        {
          "path": "mine-main/mine-main",
          "name": "templateMineMain",
          "style": {
            "navigationStyle": "custom"
          }
        }
      ]
    },
    {
      "root": "uni_modules/diary",
      "name": "xxtDiaryModule",
      "pages": [
        {
          "path": "pages/home/index",
          "name": "templateDiaryMain",
          "style": {
            "navigationStyle": "custom"
          }
        }
      ]
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "uni-app",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "custom": true,
    "selectedColor": "#4AD975",
    "color": "#999999",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/diary/diary",
        "text": "日记"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的"
      }
    ]
  }
}
